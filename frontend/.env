# =====================================
# CONFIGURACIÓN DEL BACKEND PRINCIPAL
# =====================================
NUMA_PORT=4000
JWT_SECRET=numa_secret_key_2026
MONGO_URI_NUMA=mongodb://localhost:27017/numatracking
NODE_ENV=development

# =====================================
# CONFIGURACIÓN DEL BACKEND MÓVIL
# =====================================
MOBILE_PORT=8000
MAIN_SERVER_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000/api

# =====================================
# NOTAS DE INTEGRACIÓN
# =====================================
# Backend Principal (numaServ.js):
#   - Puerto: 4000
#   - Archivo: backend-main/numaServ.js
#   - DB: MongoDB
#   - Socket.IO: Habilitado para notificaciones en tiempo real
#
# Backend Móvil (mobile.js):
#   - Puerto: 8000
#   - Archivo: backend-mobile/mobile.js
#   - Función: Proxy para login y Socket.IO bridge entre app móvil y servidor principal
#   - Conecta a: MAIN_SERVER_URL (Backend Principal)
#
# Flujo de datos:
#   1. App móvil -> Backend Móvil (puerto 8000) -> Backend Principal (puerto 4000)
#   2. Socket.IO: Backend Móvil conecta como cliente a Backend Principal
#   3. Eventos registrados en BitacoraRuta para auditoría
